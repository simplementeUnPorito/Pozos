 773:Generated_Source\PSoC5/ADC_DelSig_1.c ****             result |=  (uint16)((uint16)ADC_DelSig_1_DEC_SAMPM_REG << 8u);
 774:Generated_Source\PSoC5/ADC_DelSig_1.c ****         #endif /* CY_PSOC3 */
 775:Generated_Source\PSoC5/ADC_DelSig_1.c ****         if(coherency == ADC_DelSig_1_DEC_SAMP_KEY_HIGH)
 776:Generated_Source\PSoC5/ADC_DelSig_1.c ****         {   /* Dummy read of the MSB byte to unlock the coherency */
 777:Generated_Source\PSoC5/ADC_DelSig_1.c ****             (void)ADC_DelSig_1_DEC_SAMPH_REG;
 778:Generated_Source\PSoC5/ADC_DelSig_1.c ****         }
 779:Generated_Source\PSoC5/ADC_DelSig_1.c ****     }
 780:Generated_Source\PSoC5/ADC_DelSig_1.c ****     /* Clear conversion complete status in Single Sample mode with resolution above 16 bit */
 781:Generated_Source\PSoC5/ADC_DelSig_1.c ****     if(ADC_DelSig_1_stopConversion != 0u)
 782:Generated_Source\PSoC5/ADC_DelSig_1.c ****     {
 783:Generated_Source\PSoC5/ADC_DelSig_1.c ****         ADC_DelSig_1_convDone = 0u;
 784:Generated_Source\PSoC5/ADC_DelSig_1.c ****     }
 785:Generated_Source\PSoC5/ADC_DelSig_1.c **** 
 786:Generated_Source\PSoC5/ADC_DelSig_1.c ****     return ((int16)result);
 787:Generated_Source\PSoC5/ADC_DelSig_1.c **** }
