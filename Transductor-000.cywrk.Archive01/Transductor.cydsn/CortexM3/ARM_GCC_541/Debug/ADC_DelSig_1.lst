 727:Generated_Source\PSoC5/ADC_DelSig_1.c **** * Function Name: ADC_DelSig_1_GetResult16
 728:Generated_Source\PSoC5/ADC_DelSig_1.c **** ********************************************************************************
 729:Generated_Source\PSoC5/ADC_DelSig_1.c **** *
 730:Generated_Source\PSoC5/ADC_DelSig_1.c **** * Summary:
 731:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  Returns a 16-bit result for a conversion with a result that has a
 732:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  resolution of 8 to 16 bits. If the resolution is set greater than 16-bits,
 733:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  it will return the 16 least significant bits of the result. When the ADC
 734:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  is configured for 16-bit single ended mode, the ADC_GetResult32()
 735:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  function should be used instead. This function returns only signed
 736:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  16-bit result, which allows a maximum positive value of 32767, not 65535.
 737:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  This function supports different coherency settings.
 738:Generated_Source\PSoC5/ADC_DelSig_1.c **** *
 739:Generated_Source\PSoC5/ADC_DelSig_1.c **** * Parameters:
 740:Generated_Source\PSoC5/ADC_DelSig_1.c **** *   void
 741:Generated_Source\PSoC5/ADC_DelSig_1.c **** *
 742:Generated_Source\PSoC5/ADC_DelSig_1.c **** * Return:
 743:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  int16:  ADC result.
 744:Generated_Source\PSoC5/ADC_DelSig_1.c **** *
 745:Generated_Source\PSoC5/ADC_DelSig_1.c **** * Global variables:
 746:Generated_Source\PSoC5/ADC_DelSig_1.c **** *  ADC_DelSig_1_convDone:  Cleared in single sample mode with resolution
 747:Generated_Source\PSoC5/ADC_DelSig_1.c **** *                              above 16 bits
 748:Generated_Source\PSoC5/ADC_DelSig_1.c **** *
 749:Generated_Source\PSoC5/ADC_DelSig_1.c **** *******************************************************************************/
 750:Generated_Source\PSoC5/ADC_DelSig_1.c **** int16 ADC_DelSig_1_GetResult16(void) 
 751:Generated_Source\PSoC5/ADC_DelSig_1.c **** {
 752:Generated_Source\PSoC5/ADC_DelSig_1.c ****     uint16 result;
 753:Generated_Source\PSoC5/ADC_DelSig_1.c ****     uint8 coherency;
 754:Generated_Source\PSoC5/ADC_DelSig_1.c **** 
 755:Generated_Source\PSoC5/ADC_DelSig_1.c ****     /* Read active coherency configuration */
 756:Generated_Source\PSoC5/ADC_DelSig_1.c ****     coherency = ADC_DelSig_1_DEC_COHER_REG & ADC_DelSig_1_DEC_SAMP_KEY_MASK;
 757:Generated_Source\PSoC5/ADC_DelSig_1.c **** 
 758:Generated_Source\PSoC5/ADC_DelSig_1.c ****     if(coherency <= ADC_DelSig_1_DEC_SAMP_KEY_LOW)
 759:Generated_Source\PSoC5/ADC_DelSig_1.c ****     {   /*  Use default method to read result registers i.e. LSB byte read at the end*/
 760:Generated_Source\PSoC5/ADC_DelSig_1.c ****         #if (CY_PSOC3)
 761:Generated_Source\PSoC5/ADC_DelSig_1.c ****             result = ADC_DelSig_1_DEC_SAMPM_REG;
 762:Generated_Source\PSoC5/ADC_DelSig_1.c ****             result = (result << 8u) | ADC_DelSig_1_DEC_SAMP_REG;
 763:Generated_Source\PSoC5/ADC_DelSig_1.c ****         #else
 764:Generated_Source\PSoC5/ADC_DelSig_1.c ****             result = (CY_GET_REG16(ADC_DelSig_1_DEC_SAMP_16B_PTR));
 765:Generated_Source\PSoC5/ADC_DelSig_1.c ****         #endif /* CY_PSOC3 */
 766:Generated_Source\PSoC5/ADC_DelSig_1.c ****     }
 767:Generated_Source\PSoC5/ADC_DelSig_1.c ****     else /* MID or HIGH */
 768:Generated_Source\PSoC5/ADC_DelSig_1.c ****     {   /* Read middle byte at the end */
 769:Generated_Source\PSoC5/ADC_DelSig_1.c ****         #if (CY_PSOC3)
 770:Generated_Source\PSoC5/ADC_DelSig_1.c ****             result = (CY_GET_REG16(ADC_DelSig_1_DEC_SAMP_16B_PTR));
 771:Generated_Source\PSoC5/ADC_DelSig_1.c ****         #else
 772:Generated_Source\PSoC5/ADC_DelSig_1.c ****             result = ADC_DelSig_1_DEC_SAMP_REG;
